# Copy to .env, fill in, then `set -a && source .env && set +a` before running.

# Firebase web API key for the project the DartStream backend trusts.
# Get it from Firebase console > Project settings > your web app.
# This file is the public template — put the real value only in your local .env (gitignored).
FIREBASE_API_KEY=your-firebase-web-api-key

# Test user for the smoke CLI. On first run the user won't exist, so the CLI
# auto-signs them up — any valid email + strong password works.
TEST_EMAIL=you@example.com
TEST_PASSWORD=change-me

# Per-service base URLs. Defaults match dev-api.dartstream.io subdomain pattern.
API_AUTH=https://dev-apiauth.dartstream.io
API_PLATFORM=https://dev-apiplatform.dartstream.io
API_EXPERIENCE=https://dev-apiexperience.dartstream.io
API_REACTIVE=https://dev-apireactive.dartstream.io
API_PERSISTENCE=https://dev-apipersistence.dartstream.io

# OAuth2 client_credentials (machine-to-machine) — used by bin/oauth2_deepdive.dart.
# The secret is confidential: put it only in your local .env (gitignored).
API_BILLING=https://dev-apibilling.dartstream.io
OAUTH2_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OAUTH2_CLIENT_SECRET=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# IntelliToggle — Aortem's feature-flag SaaS, consumed via the OpenFeature provider.
# The provider does the OAuth2 client-credentials exchange internally; create an
# OAuth client in the IntelliToggle dashboard and copy clientId + clientSecret +
# tenantId ONCE. The secret is confidential — put it only in your local .env (gitignored).
# Used by bin/intellitoggle_deepdive.dart.
INTELLITOGGLE_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INTELLITOGGLE_CLIENT_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INTELLITOGGLE_TENANT_ID=tenant_xxxxxxxxxxxxxxxxxx
# Host override. Defaults to PROD (https://api.intellitoggle.com).
# If your OAuth client was created on the DEV dashboard set this to the dev host
# or the client_credentials handshake will 401 (invalid_client).
INTELLITOGGLE_API_URL=https://dev-api.intellitoggle.com

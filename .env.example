# Copy to .env and fill in real values. .env is gitignored.
# Load before running the bin/ CLIs: `set -a && source .env && set +a`.

# Firebase web API key for the dartstream-prod project (the issuer the
# DartStream backend trusts). For this sample app it's the public web key
# from the Firebase console > Project settings.
FIREBASE_API_KEY=

# Test account the smoke / deep-dive CLIs sign in with (auto-signs-up on
# first run).
TEST_EMAIL=
TEST_PASSWORD=

# Per-service base URLs. Defaults target the SaaS dev environment.
# Override only if you're pointing at a different DartStream environment.
API_AUTH=https://dev-api-auth.dartstream.io
API_PLATFORM=https://dev-api-platform.dartstream.io
API_EXPERIENCE=https://dev-api-experience.dartstream.io
API_REACTIVE=https://dev-api-reactive.dartstream.io
API_PERSISTENCE=https://dev-api-persistence.dartstream.io

# Project / environment the budget splitter scopes its data under.
PROJECT_ID=fintech-budget-splitter
ENVIRONMENT_ID=development
